{
  "name": "aws-bedrock-news-curator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test && pnpm cdk:synth",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "cdk": "AWS_PROFILE=${AWS_PROFILE:-bedrock-news-deploy} cdk",
    "cdk:deploy": "AWS_PROFILE=${AWS_PROFILE:-bedrock-news-deploy} cdk deploy",
    "cdk:synth": "AWS_PROFILE=${AWS_PROFILE:-bedrock-news-deploy} cdk synth",
    "whoami:aws": "AWS_PROFILE=${AWS_PROFILE:-bedrock-news-deploy} aws sts get-caller-identity"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.828.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.828.0",
    "aws-cdk-lib": "^2.199.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.32",
    "aws-cdk": "^2.1019.2",
    "esbuild": "^0.25.5",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "packageManager": "pnpm@10.12.1"
}
